bootload","bottom","build","build.","build/left","build/right","button","c","choc","column","configur","configurations.","control","controller:","copi","d","devic","dshield=totem_left","dshield=totem_right","e","edit","editor","enter","featur","file","firmwar","first","first.","flash","geigeigeist","github","graphic","half","half)","hardwar","hot","index","key","keyboard","keyboard:","keymap","label","led","left","lilfeelz","live","local","main","mass","matrix:","mini","mount","open","oper","overview","per","power","preview.","push","repo","reset","rgb:","row","s","seeed","sk6812","socket","soldering.","split","stagger","staggered,","start","storag","swap","switches:","tap","total)","totem","trigger","under","underglow","us","usb","v1","visual","west","wireless","xiao","xiao_bl","zmk","zmk/app","×","—","↗"],"pipeline":["stopWordFilter","stemmer"]},"store":{"editor.html":{"url":"editor.html","title":"Keymap Editor","keywords":"","body":"Visual Editor\nOpen the keymap in the ZMK keymap editor for graphical editing and live preview.\nStart Keymap Editor ↗\n"},"./":{"url":"./","title":"Keyboard Index","keywords":"","body":"lilfeelz ZMK Configuration\nKeyboard firmware configurations.\n\nTOTEM — 38-key split column-staggered, Seeed XIAO BLE\n\n"},"totem/":{"url":"totem/","title":"Overview","keywords":"","body":"TOTEM ZMK Configuration\nZMK firmware configuration for the TOTEM keyboard — a 38-key split column-staggered keyboard powered by Seeed XIAO BLE.\nKeymap\n\n"},"totem/hardware.html":{"url":"totem/hardware.html","title":"Hardware","keywords":"","body":"Hardware\n\nKeyboard: TOTEM by GEIGEIGEIST\nController: Seeed XIAO BLE (nRF52840) × 2\nMatrix: 6 columns × 3 rows per half (36 keys total)\nSwitches: Choc v1 (PG1350)\nRGB: SK6812 MINI-E underglow (6 LEDs per half)\n\nFeatures\n\nHot-swap Choc sockets\nUSB-C or wireless (BLE) operation\nReset button accessible from bottom\n\n"},"totem/flashing.html":{"url":"totem/flashing.html","title":"Building & Flashing","keywords":"","body":"Building & Flashing\nLocal Build\nwest build -b xiao_ble -d build/left  -s zmk/app -- -DSHIELD=totem_left\nwest build -b xiao_ble -d build/right -s zmk/app -- -DSHIELD=totem_right\n\nGitHub Actions\nThis repo uses the ZMK Build Action. Push to main to trigger a build. Firmware artifacts available under Actions.\nFlashing\n\nEnter bootloader (double-tap reset on XIAO BLE)\nCopy the .uf2 file to the mounted mass-storage device\nDevice resets automatically\n\nFirst flash\nLeft half must be flashed first. Label controllers before soldering.\n"}}}